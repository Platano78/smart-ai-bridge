{
  "name": "smart-ai-bridge",
  "version": "2.6.0",
  "description": "MCP server for Claude Code — multi-AI orchestration across local + cloud LLMs, intelligent backend routing, council-driven workflows, and token-saving file operations.",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "start:legacy": "node smart-ai-bridge-v1.1.0.js",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:legacy": "node scripts/validate-hybrid-server.js",
    "test:features": "node run-comprehensive-feature-tests.js",
    "test:conversation": "node test-conversation-threading.js",
    "test:analytics": "node test-usage-analytics.js",
    "test:bench": "node tests/benchmark.js",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "ai",
    "llm",
    "local-llm",
    "llama-cpp",
    "ollama",
    "multi-agent",
    "ai-orchestration",
    "routing",
    "anthropic",
    "openai",
    "gemini",
    "deepseek",
    "nvidia",
    "groq",
    "bridge"
  ],
  "author": "",
  "license": "Apache-2.0",
